# Runtime secrets for local Next.js (`cp .env.example .env.local`)
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_IDS=123456789
QBITTORRENT_URL=https://your-qb.example.com
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
CRON_SECRET=

# Optional: comma-separated hosts for in-app browse proxy (empty = all public hosts).
# Example: example.com,*.wikimedia.org
BROWSE_ALLOWED_HOSTS=

# GitHub Actions Variable only (webhook / menu button).
# Not needed in .env.local or Cloudflare Worker secrets.
# Notify cron runs on Cloudflare Workers (see wrangler.jsonc triggers.crons).
APP_URL=https://tg-dl.your-subdomain.workers.dev
