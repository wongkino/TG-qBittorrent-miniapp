# Runtime secrets for local Next.js (`cp .env.example .env.local`)
TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_IDS=123456789
QBITTORRENT_URL=https://your-qb.example.com
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
