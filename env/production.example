# ── Production reference (Cloudflare Worker + GitHub Actions) ──
# Do NOT commit real values. Do NOT enable DEV_PREVIEW here.
#
# Placement:
#   GitHub Secrets     → QBITTORRENT_USERNAME,
#                        QBITTORRENT_PASSWORD,
#                        CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID
#   GitHub Variables   → ALLOWED_GOOGLE_EMAILS,
#                        GOOGLE_CLIENT_ID, QBITTORRENT_URL
#   Worker Secrets     → synced by Deploy (all except CLOUDFLARE_*)
#
# See docs/reference/environment.md and docs/guides/deployment.md.

QBITTORRENT_URL=https://your-qb.example.com
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# Web App — Google OAuth (Worker + browser sign-in; client id is public).
GOOGLE_CLIENT_ID=
ALLOWED_GOOGLE_EMAILS=you@gmail.com

# GitHub Secrets only (Actions deploy), not Worker runtime:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
